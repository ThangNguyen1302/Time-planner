# Database
DB_URL=jdbc:mysql://localhost:3306/timeplanner?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# JWT: use a random value with at least 32 bytes
JWT_SECRET=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/integrations/google/callback
# Comma-separated when you need more than one allowed frontend origin.
FRONTEND_URL=http://localhost:3000

# Choose one: openrouter, openai, gemini
ASSISTANT_PROVIDER=gemini

# Configure only the selected provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
